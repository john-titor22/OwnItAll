{
  "expo": {
    "name": "Own It All",
    "slug": "own-it-all",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ownitall",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": false },
    "android": { "adaptiveIcon": { "backgroundColor": "#1a1a2e" } },
    "platforms": ["ios", "android", "web"],
    "plugins": ["expo-router"],
    "web": {
      "bundler": "metro",
      "output": "single",
      "name": "Own It All",
      "shortName": "OwnItAll",
      "description": "Marrakech Edition — multiplayer property trading game",
      "themeColor": "#C9A84C",
      "backgroundColor": "#0A0A16",
      "display": "standalone",
      "orientation": "portrait"
    },
    "experiments": { "typedRoutes": true }
  }
}
